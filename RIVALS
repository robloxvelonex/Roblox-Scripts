-- ==========================================
-- UTILS
-- ==========================================
local function IsKeyDown(k)
    if not k then return false end
    if typeof(k) ~= "EnumItem" then return false end
    if k.EnumType == Enum.UserInputType then return UIS:IsMouseButtonPressed(k) end
    if k.EnumType == Enum.KeyCode then return UIS:IsKeyDown(k) end
    return false
end

local function SafeLoad(url, name)
    local ok, res = pcall(function() return loadstring(game:HttpGet(url))() end)
    if not ok then warn("[RIVALS HUB] Failed to load " .. name .. ": " .. tostring(res)); return nil end
    return res
end

local function NewDraw(kind, props)
    local ok, obj = pcall(Drawing.new, kind)
    if not ok then return nil end
    for k, v in pairs(props) do
        pcall(function() obj[k] = v end)
    end
    return obj
end

local function HideESP(sk)
    if sk then
        if sk.Box    then sk.Box.Visible    = false end
        if sk.BG     then sk.BG.Visible     = false end
        if sk.Bar    then sk.Bar.Visible    = false end
        if sk.Text   then sk.Text.Visible   = false end
    end
end

local function CleanChams(char)
    if char then
        local h = char:FindFirstChild("RivalsChams")
        if h then h.Enabled = false end
    end
end

-- Team Check: returns true if player is an ENEMY (should be targeted)
local function IsEnemy(p)
    if not _G.TeamCheck then return true end -- Team Check off = target everyone
    -- Same team = not an enemy
    if LocalPlayer.Team and p.Team and LocalPlayer.Team == p.Team then
        return false
    end
    return true
end

