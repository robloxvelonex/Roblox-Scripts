    if sk then
        if sk.Box   then pcall(function() sk.Box:Remove()   end) end
        if sk.BG    then pcall(function() sk.BG:Remove()    end) end
        if sk.Bar   then pcall(function() sk.Bar:Remove()   end) end
        if sk.Text  then pcall(function() sk.Text:Remove()  end) end
        Skeletons[p] = nil
    end
    VisCache[p] = nil
end)

-- Main render loop
RS.RenderStepped:Connect(function()
    local cam = Camera
    if not cam then return end

    -- FOV circle
    FovCircle.Visible  = _G.ShowFOV
    FovCircle.Radius   = _G.AimbotFOV
    FovCircle.Position = UIS:GetMouseLocation()

    -- Aimbot
    if _G.AimbotActive then
        local firing = false
        if _G.AimbotMode == "Hold" then
            firing = IsKeyDown(_G.AimbotKey)
        else
            firing = _G.AimbotToggled
        end
        if firing then
            local t = GetTarget()
            if t then
                local goal = CFrame.lookAt(cam.CFrame.Position, t.Position)
                -- Map 1-100 to lerp factor: 100 = instant (1.0), 1 = very soft (~0.01)
                local factor = _G.AimbotSmooth / 100
                if factor >= 0.99 then
                    cam.CFrame = goal  -- Instant snap at max
                else
                    cam.CFrame = cam.CFrame:Lerp(goal, factor)
                end
            end
        end
    end

    -- ESP per player
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local isEnemy = IsEnemy(p)

        -- Create drawings for this player if missing
        if not Skeletons[p] then
            Skeletons[p] = {
                Box  = NewDraw("Square", {Thickness=1, Color=Color3.fromRGB(255,255,255), Visible=false}),
                BG   = NewDraw("Square", {Thickness=0, Color=Color3.fromRGB(0,0,0), Filled=true, Visible=false, Transparency=0.55}),
                Bar  = NewDraw("Square", {Thickness=0, Color=Color3.fromRGB(0,255,0), Filled=true, Visible=false}),
                Text = NewDraw("Text",   {Size=12, Center=true, Outline=true, Color=Color3.fromRGB(255,255,255), Visible=false}),
            }
        end

        local sk   = Skeletons[p]
        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChild("Humanoid")

        -- Hide everything if character is gone / dead OR teammate
        if not hrp or not hum or hum.Health <= 0 or not isEnemy then
            HideESP(sk); CleanChams(char); continue
        end

        local rootPos        = hrp.Position
        local screen, onScr  = cam:WorldToViewportPoint(rootPos)

        -- Box ESP + Health bar
        if _G.BoxESP and onScr then
            local topPos = cam:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, 3,    0)).Position)
            local botPos = cam:WorldToViewportPoint((hrp.CFrame * CFrame.new(0, -3.5, 0)).Position)
            local h = math.abs(topPos.Y - botPos.Y)
            local w = h / 1.8
            local left = topPos.X - w / 2

            sk.Box.Position = Vector2.new(left, topPos.Y)
            sk.Box.Size     = Vector2.new(w, h)
            sk.Box.Visible  = true

            -- Health bar (right side)
            local hPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            local barX  = left + w + 4
            sk.BG.Position  = Vector2.new(barX, topPos.Y)
            sk.BG.Size      = Vector2.new(3, h)
            sk.BG.Visible   = true
            sk.Bar.Position = Vector2.new(barX, topPos.Y + h * (1 - hPct))
            sk.Bar.Size     = Vector2.new(3, h * hPct)
            sk.Bar.Color    = Color3.fromHSV(hPct * 0.33, 1, 1)
            sk.Bar.Visible  = true
        else
            sk.Box.Visible = false; sk.BG.Visible = false; sk.Bar.Visible = false
        end

        -- Distance ESP
        if _G.DistanceESP and onScr then
            local dist = (cam.CFrame.Position - rootPos).Magnitude
            sk.Text.Position = Vector2.new(screen.X, screen.Y)
            sk.Text.Text     = string.format("[%d m]", dist)
            sk.Text.Visible  = true
        else
            sk.Text.Visible = false
        end

        -- Chams (Highlight)
        if _G.ChamsActive then
            local hi = char:FindFirstChild("RivalsChams")
            if not hi then hi = Instance.new("Highlight", char); hi.Name = "RivalsChams" end
            hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hi.Enabled   = true
            local isVis  = VisCache[p] == true
            local col    = isVis and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
            hi.FillColor        = col
            hi.OutlineColor     = col
            hi.FillTransparency = 0.5
        else
            CleanChams(char)
        end
    end
end)

