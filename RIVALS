-- Raycast: is target visible?
local function IsVisible(origin, target, char)
    local lc = LocalPlayer.Character
    local filter = {char}
    if lc then table.insert(filter, lc) end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = filter
    params.FilterType = Enum.RaycastFilterType.Exclude
    local dir = target - origin
    local ray = workspace:Raycast(origin, dir, params)
    -- No hit = visible. Hit something transparent/non-collidable = still visible
    if not ray then return true end
    return (ray.Instance.Transparency > 0.5 or not ray.Instance.CanCollide)
end

-- Get closest player to mouse within FOV
local function GetTarget()
    local best, bestDist = nil, _G.AimbotFOV
    local mouse = UIS:GetMouseLocation()
    local cam   = Camera
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if not IsEnemy(p) then continue end  -- Skip teammates
        local char = p.Character
        if not char then continue end
        local part = char:FindFirstChild(_G.AimbotPart) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        local hum = char:FindFirstChild("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local screen, onScreen = cam:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local dist2D = (Vector2.new(screen.X, screen.Y) - mouse).Magnitude
        if dist2D < bestDist then
            if IsVisible(cam.CFrame.Position, part.Position, char) then
                bestDist = dist2D
                best = part
            end
        end
    end
    return best
end

-- Toggle input for aimbot
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if _G.AimbotMode ~= "Toggle" then return end
    local matchMouse = input.UserInputType == _G.AimbotKey
    local matchKey   = (typeof(_G.AimbotKey) == "EnumItem" and _G.AimbotKey.EnumType == Enum.KeyCode and input.KeyCode == _G.AimbotKey)
    if matchMouse or matchKey then
        _G.AimbotToggled = not _G.AimbotToggled
    end
end)

-- Visibility background updater for Chams (runs every 0.12s)
task.spawn(function()
    while true do
        task.wait(0.12)
        if not _G.ChamsActive then continue end
        local cam = Camera
        local origin = cam.CFrame.Position
        for _, p in ipairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            local char = p.Character
            if not char then VisCache[p] = false; continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                VisCache[p] = IsVisible(origin, hrp.Position, char)
            else
                VisCache[p] = false
            end
        end
    end
end)

-- Player cleanup
Players.PlayerRemoving:Connect(function(p)
